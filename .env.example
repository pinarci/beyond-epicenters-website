# Example environment variables
# Copy this file to .env.local and fill in your values

# Optional: Your website URL for Open Graph metadata
NEXT_PUBLIC_SITE_URL=https://beyond-epicenters.example.com

# Optional: Analytics tracking ID (if using Google Analytics)
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X

# Optional: Contact email (can be used in footer)
# NEXT_PUBLIC_CONTACT_EMAIL=info@tedustam.org
